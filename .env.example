POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_secure_db_password
POSTGRES_DB=duro_image_builder
REDIS_URL=redis://redis:6380/0
DATABASE_URL=postgresql://postgres:your_secure_db_password@db:5433/duro_image_builder

# Exposed Ports
BACKEND_PORT=8003

# Authentication
SUPERADMIN_USERNAME=admin
ADMIN_PASSWORD=your_secure_superadmin_password
JWT_SECRET_KEY=your_secure_jwt_secret_key_change_me

# Workspace & Artifact Storage Path (Host path e.g. /data/duro or named volume duro-workspace)
DURO_HOST_DATA_PATH=duro-workspace
DURO_WORKSPACE_PATH=/opt/data/duro_workspace
